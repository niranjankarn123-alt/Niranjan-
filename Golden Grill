        // NAVIGATION ENGINE
        function showPage(pageId) {
            // Hide all pages
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            // Show selected page
            document.getElementById(pageId).classList.add('active');
            // Reset menu view if navigating to menu page
            if(pageId === 'menu-view') backToFolders();
            // Scroll to top
            window.scrollTo(0,0);
        }

        // CUISINE FOLDER LOGIC
        function openCuisine(cuisineName) {
            document.getElementById('cuisine-folder-view').style.display = 'none';
            document.getElementById('cuisine-items-view').style.display = 'block';
            document.getElementById('current-cuisine-title').innerText = cuisineName + " Cuisine";
            
            const target = document.getElementById('menu-content-target');
            target.innerHTML = '';
            
            const categories = masterMenu[cuisineName];
            for(let catName in categories) {
                let html = `<h3 class="menu-cat">${catName}</h3>`;
                for(let itemName in categories[catName]) {
                    html += `<div class="menu-row"><span>${itemName}</span><span class="price">₹${categories[catName][itemName]}</span></div>`;
                }
                target.innerHTML += html;
            }
            window.scrollTo(0,0);
        }

        function backToFolders() {
            document.getElementById('cuisine-items-view').style.display = 'none';
            document.getElementById('cuisine-folder-view').style.display = 'block';
        }
    </script>
