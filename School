<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>School Excellence | Nursery to XII</title>
    <style>
        /* --- Theme Colors --- */
        :root {
            --dark-beach: #2C3E50; /* Deep Ocean/Dark Sand */
            --light-beach: #F2E3D5; /* Soft Sand */
            --white: #FFFFFF;
            --accent: #D4A373;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }

        body { background-color: var(--light-beach); color: var(--dark-beach); }

        /* --- Header Section --- */
        header {
            background-color: var(--dark-beach);
            color: var(--white);
            padding: 15px 5%;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

        .top-bar {
            display: flex;
            justify-content: flex-end;
            font-size: 0.9rem;
            margin-bottom: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding-bottom: 5px;
        }

        .main-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .school-name {
            font-family: "Times New Roman", Times, serif;
            font-size: 1.8rem;
            font-weight: bold;
        }

        nav ul {
            display: flex;
            list-style: none;
        }

        nav ul li {
            margin-left: 20px;
            cursor: pointer;
            transition: 0.3s;
            font-weight: 500;
        }

        nav ul li:hover { color: var(--accent); }

        /* --- Content Sections --- */
        .container { padding: 40px 10%; min-height: 80vh; }
        .page { display: none; animation: fadeIn 0.5s; }
        .active { display: block; }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        h2 { margin-bottom: 20px; border-left: 5px solid var(--dark-beach); padding-left: 15px; }

        /* --- Home: Image Slider Placeholder --- */
        .slider {
            width: 100%;
            height: 400px;
            background: url('https://images.unsplash.com/photo-1544148103-0773bf10d330?auto=format&fit=crop&w=1200&q=80') center/cover;
            border-radius: 15px;
            margin-bottom: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        }

        .quote-box {
            background: rgba(44, 62, 80, 0.8);
            padding: 20px;
            border-radius: 10px;
            text-align: center;
            font-style: italic;
        }

        /* --- Form Styling --- */
        form { background: white; padding: 30px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
        .form-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: bold; }
        input, select { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px; }
        button { 
            background: var(--dark-beach); color: white; border: none; 
            padding: 12px 25px; border-radius: 5px; cursor: pointer; font-size: 1rem;
        }
        button:hover { background: #1a252f; }

        /* --- Grid for Events/About --- */
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; }
        .card { background: white; padding: 20px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        .card img { width: 100%; height: 180px; object-fit: cover; border-radius: 5px; margin-bottom: 15px; }

        /* --- Table --- */
        table { width: 100%; border-collapse: collapse; background: white; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
        th { background: var(--dark-beach); color: white; }
    </style>
</head>
<body>

<header>
    <div class="top-bar">
        <span>📧 email@school.edu | 📞 +1 234 567 890</span>
    </div>
    <div class="main-nav">
        <div class="school-name">BEACHSIDE INTERNATIONAL ACADEMY</div>
        <nav>
            <ul>
                <li onclick="showPage('home')">Home</li>
                <li onclick="showPage('about')">About Us</li>
                <li onclick="showPage('enrollment')">Academic Enrollment</li>
                <li onclick="showPage('events')">School Events</li>
                <li onclick="showPage('fee')">Fee Structure</li>
            </ul>
        </nav>
    </div>
</header>

<div class="container">
    <section id="home" class="page active">
        <div class="slider">
            <div class="quote-box">
                <h1>"The beautiful thing about learning is that no one can take it away from you."</h1>
                <p>- B.B. King</p>
            </div>
        </div>
        <h2>Welcome to Excellence</h2>
        <p>Providing quality education from Nursery to Grade XII in a serene environment.</p>
    </section>

    <section id="about" class="page">
        <h2>About Our Institution</h2>
        <div class="grid">
            <div class="card">
                <h3>Experienced Teachers</h3>
                <p>Our faculty consists of PhD and Masters holders dedicated to nurturing young minds.</p>
            </div>
            <div class="card">
                <h3>Great Infrastructure</h3>
                <p>Modern classrooms equipped with smart boards and ergonomic furniture.</p>
            </div>
            <div class="card">
                <h3>Luxurious Facilities</h3>
                <p>Olympic-sized swimming pools, AC auditoriums, and world-class labs.</p>
            </div>
            <div class="card">
                <h3>Hygiene & Safety</h3>
                <p>Strict sanitization protocols and 24/7 CCTV monitoring across campus.</p>
            </div>
        </div>
    </section>

    <section id="enrollment" class="page">
        <h2>Admission Inquiry Form</h2>
        <form id="enrollForm">
            <div class="form-group">
                <label>Student Name</label>
                <input type="text" required>
            </div>
            <div class="form-group">
                <label>Parent/Guardian Name</label>
                <input type="text" required>
            </div>
            <div class="form-group">
                <label>Target Class</label>
                <select>
                    <option>Nursery - UKG</option>
                    <option>I - V</option>
                    <option>VI - X</option>
                    <option>XI - XII</option>
                </select>
            </div>
            <div class="form-group">
                <label>Previous Year Grade</label>
                <input type="text">
            </div>
            <div class="form-group">
                <label>Contact Number</label>
                <input type="tel" required>
            </div>
            <div class="form-group">
                <label>Email ID</label>
                <input type="email" required>
            </div>
            <button type="button" onclick="submitForm()">Submit Application</button>
        </form>
    </section>

    <section id="events" class="page">
        <h2>Upcoming & Past Events</h2>
        <div class="grid">
            <div class="card">
                <img src="https://images.unsplash.com/photo-1511578314322-379afb476865?auto=format&fit=crop&w=400&q=80" alt="Annual Day">
                <h3>Annual Event</h3>
                <p>A grand celebration of arts, culture, and student achievements.</p>
            </div>
            <div class="card">
                <img src="https://images.unsplash.com/photo-1509062522246-3755977927d7?auto=format&fit=crop&w=400&q=80" alt="Fair">
                <h3>Educational Funfair</h3>
                <p>Combining science projects with fun games and food stalls.</p>
            </div>
            <div class="card">
                <img src="https://images.unsplash.com/photo-1461891211039-49b16cc42398?auto=format&fit=crop&w=400&q=80" alt="Sports">
                <h3>Sports Week</h3>
                <p>Developing sportsmanship and physical fitness through competition.</p>
            </div>
        </div>
    </section>

    <section id="fee" class="page">
        <h2>Fee Structure (Academic Year 2026)</h2>
        <table>
            <tr>
                <th>Grade Level</th>
                <th>Monthly Fee</th>
                <th>Quarterly Fee</th>
            </tr>
            <tr>
                <td>Nursery - UKG</td>
                <td>$200</td>
                <td>$550</td>
            </tr>
            <tr>
                <td>Grade I - VIII</td>
                <td>$350</td>
                <td>$950</td>
            </tr>
            <tr>
                <td>Grade IX - XII</td>
                <td>$500</td>
                <td>$1,400</td>
            </tr>
        </table>
        <div style="margin-top: 20px; background: #d4a373; padding: 15px; border-radius: 5px; font-weight: bold;">
            🎉 SPECIAL DISCOUNTS: 5% Off on Half-Yearly payments | 10% Off on Yearly Lump-sum payment!
        </div>
    </section>
</div>

<script>
    function showPage(pageId) {
        // Hide all pages
        const pages = document.querySelectorAll('.page');
        pages.forEach(page => page.classList.remove('active'));
        
        // Show selected page
        document.getElementById(pageId).classList.add('active');
        
        // Scroll to top
        window.scrollTo(0,0);
    }

    function submitForm() {
        alert("Thank you for your interest! You will be notified soon.");
        document.getElementById('enrollForm').reset();
        showPage('home');
    }
</script>

</body>
</html>
